{
	"schemaVersion": 1,
	"id": "snow-settings",
	"version": "${version}",
	"name": "Advanced Snow Settings",
	"description": "Adds additional settings for falling snow, e.g which blocks they can fall on and if snow can melt.",
    "authors": [
      "Lloyd Archer (Murf Games)"
    ],
    "contact": {
      "homepage": "http://murfgames.co.uk/",
		"sources": "https://github.com/mrflappi/MurfTweaks"
	},
	"license": "MIT",
	"icon": "assets/murf-tweaks/icons/snow-settings.png",
	"environment": "*",
	"entrypoints": {
        "main": [
          "net.murfgames.murftweaks.snowsettings.SnowSettingsModule"
        ],
		"preLaunch": [
          "net.murfgames.murftweaks.snowsettings.SnowSettingsModule"
        ]
    },
	"mixins": [
        "snow-settings.mixins.json",
        {
          "config": "snow-settings.client.mixins.json",
          "environment": "client"
        }
	],
	"depends": {
        "fabricloader": ">=0.18.4",
        "minecraft": "~1.21.11",
        "java": ">=21",
        "fabric-api": "*",
        "bibliomurf": ">=0.5.1-1.21.11"
	}
}