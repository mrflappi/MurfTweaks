{
	"schemaVersion": 1,
	"id": "persistent-enchantment",
	"version": "${version}",
	"name": "Persistent Enchantment",
	"description": "Adds a 'Persistent' enchantment which overrides mending - imitates elytra behaviour by making the item unusable at 1 durability, preventing permanent item loss. However, persistent items do not heal from xp, they must still be repaired in an anvil. I suggest downloading a mod which disables anvil price increasing.",
	"authors": [
		"Lloyd Archer (Murf Games)"
	],
	"contact": {
		"homepage": "http://luhloyda.co.uk/",
        "sources": "https://github.com/mrflappi/MurfTweaks"
	},
	"license": "MIT",
	"icon": "assets/murf-tweaks/icons/persistent-enchantment.png",
	"environment": "*",
	"entrypoints": {
        "main": [
          "net.murfgames.murftweaks.persistentenchantment.PersistentEnchantmentModule"
        ],
        "preLaunch": [
          "net.murfgames.murftweaks.persistentenchantment.PersistentEnchantmentModule"
        ]
    },
	"mixins": [
        "persistent-enchantment.mixins.json",
		{
			"config": "persistent-enchantment.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*",
		"bibliomurf": ">=0.5.4-26.2"
	}
}