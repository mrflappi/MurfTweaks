{
	"schemaVersion": 1,
	"id": "path-under",
	"version": "${version}",
	"name": "Path Under Replaceables",
	"description": "Allows the player to place paths underneath replaceable blocks e.g. snow or grass",
    "authors": [
      "Lloyd Archer (Murf Games)"
    ],
    "contact": {
      "homepage": "http://luhloyda.co.uk/",
		"sources": "https://github.com/mrflappi/MurfTweaks"
	},
	"license": "MIT",
	"icon": "assets/murf-tweaks/icons/path-under.png",
	"environment": "*",
	"entrypoints": {
        "main": [
          "net.murfgames.murftweaks.pathunder.PathUnderModule"
        ],
		"preLaunch": [
          "net.murfgames.murftweaks.pathunder.PathUnderModule"
        ]
    },
	"mixins": [
        "path-under.mixins.json",
        {
          "config": "path-under.client.mixins.json",
          "environment": "client"
        }
	],
	"depends": {
        "fabricloader": ">=0.19.2",
        "minecraft": "~26.1.2",
        "java": ">=25",
        "fabric-api": "*",
        "bibliomurf": ">=0.5.4-26.1.2"
	}
}